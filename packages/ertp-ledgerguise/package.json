{
  "name": "@finquick/ertp-ledgerguise",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen:sql": "node scripts/codegen-sql.mjs",
    "lint:types": "tsc -p tsconfig.json --noEmit --incremental",
    "test": "ava",
    "check": "npm run lint:types && npm run test"
  },
  "ava": {
    "extensions": {
      "js": true,
      "ts": "module"
    },
    "files": [
      "test/**/*.test.*"
    ],
    "nodeArguments": [
      "--import=ts-blank-space/register",
      "--no-warnings"
    ],
    "require": []
  },
  "dependencies": {
    "@agoric/ertp": "0.16.3-dev-dc67c18.0.dc67c18",
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.1",
    "ava": "^5.3.1",
    "ts-blank-space": "^0.6.2",
    "typescript": "~5.9.3"
  }
}
